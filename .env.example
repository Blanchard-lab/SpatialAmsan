# SpatialAmsan — API key template
# -------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and paste your keys.
# Only the providers you plan to evaluate need a key; leave others blank.
# NEVER commit a filled-in .env. Revoke & rotate any key exposed by mistake.

# OpenAI (GPT family)
OPENAI_API_KEY=

# Anthropic (Claude family)
ANTHROPIC_API_KEY=

# Google (Gemini family)
GOOGLE_API_KEY=
